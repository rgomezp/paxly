{
  "name": "anxietytracker",
  "version": "0.0.1",
  "private": true,
  "main": "index.tsx",
  "scripts": {
    "compile": "tsc --noEmit -p . --pretty",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "patch": "patch-package",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:maestro": "maestro test .maestro/FavoritePodcast.yaml",
    "adb": "adb reverse tcp:9090 tcp:9090 && adb reverse tcp:3000 tcp:3000 && adb reverse tcp:9001 tcp:9001 && adb reverse tcp:8081 tcp:8081",
    "postinstall": "patch-package",
    "start": "source env.sh && yarn test && export APP_VARIANT='development' && expo start --dev-client",
    "start:skip": "source env.sh && export APP_VARIANT='development' && expo start --dev-client",
    "build": "tsc",
    "build:android-dev": "yarn test && ./scripts/check_build_size android && source env.sh && export NODE_ENV='development' && eas build --profile development --platform android --local",
    "build:android-preview": "yarn test && ./scripts/check_build_size android && ./scripts/updateAndroidVersionCode && eas build --profile preview --platform android",
    "build:android-production": "yarn test && ./scripts/check_build_size android && ./scripts/updateAndroidVersionCode && eas build --profile production --platform android",
    "build:ios-dev": "source env.sh && yarn test && ./scripts/check_build_size ios && export APP_VARIANT='development' && eas build --profile development-simulator --platform ios --local",
    "build:ios-preview": "yarn test && ./scripts/check_build_size ios && eas build --profile preview --platform ios",
    "build:ios-production": "source env.sh && yarn test && ./scripts/check_build_size ios && ./scripts/update_ios_build_number && eas build --profile production --platform ios",
    "publish:ios-production": "eas submit -p ios --profile production",
    "alignDependencies": "./alignDeps.sh",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "bundle:web": "npx expo export --platform web",
    "serve:web": "npx serve dist",
    "prebuild:clean": "npx expo prebuild --clean",
    "updateGoogleServicesJson": "eas secret:create --scope project --name GOOGLE_SERVICES_JSON --type file --value googleServices/google-services.json",
    "updateGoogleServicesPlist": "eas secret:create --scope project --name GOOGLE_SERVICES_PLIST --type file --value googleServices/GoogleService-Info.plist",
    "encodeGoogleServicesJson": "./scripts/encode_google_services_json",
    "encodeGoogleServicesPlist": "./scripts/encode_google_services_plist",
    "encodeGooglePlaySubmitter": "./scripts/encode_google_play_submitter",
    "test-archive-ios": "rm -rf ../test_archive && eas build:inspect --platform ios --stage archive --output ../test_archive --profile production",
    "test-archive-android": "rm -rf ../test_archive && eas build:inspect --platform android --stage archive --output ../test_archive --profile production",
    "eas-build-pre-install": "./scripts/eas_pre_install"
  },
  "dependencies": {
    "@expo-google-fonts/space-grotesk": "^0.2.2",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@potionforge/ganon": "^1.0.0-beta.3",
    "@react-native-firebase/analytics": "23.4.1",
    "@react-native-firebase/app": "23.4.1",
    "@react-native-firebase/app-check": "23.4.1",
    "@react-native-firebase/auth": "23.4.1",
    "@react-native-firebase/crashlytics": "23.4.1",
    "@react-native-firebase/firestore": "23.4.1",
    "@react-native-firebase/storage": "23.4.1",
    "@react-native-google-signin/google-signin": "^13.2.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "@shopify/flash-list": "2.0.2",
    "apisauce": "3.0.1",
    "date-fns": "^4.1.0",
    "eventemitter3": "^5.0.1",
    "expo": "^54.0.0",
    "expo-apple-authentication": "~8.0.8",
    "expo-application": "~7.0.8",
    "expo-asset": "~12.0.12",
    "expo-audio": "~1.1.1",
    "expo-build-properties": "~1.0.10",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-splash-screen": "^31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-store-review": "~9.0.9",
    "expo-system-ui": "~6.0.9",
    "intl-pluralrules": "^2.0.1",
    "jwt-decode": "^4.0.0",
    "lodash": "^4.17.21",
    "lottie-react-native": "~7.3.1",
    "mobx": "6.10.2",
    "mobx-react-lite": "4.0.5",
    "mobx-state-tree": "5.3.0",
    "onesignal-expo-plugin": "^2.0.3",
    "phosphor-react-native": "^3.0.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-date-picker": "^5.0.13",
    "react-native-drawer-layout": "^4.0.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-mmkv": "2.12.2",
    "react-native-modal": "^14.0.0-rc.1",
    "react-native-onesignal": "5.3.0-beta-01",
    "react-native-purchases": "^9.6.6",
    "react-native-purchases-ui": "^9.6.6",
    "react-native-reanimated": "~3.17.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@testing-library/react-native": "^12.5.2",
    "@types/eventemitter3": "^2.0.4",
    "@types/jest": "29.5.14",
    "@types/lodash": "^4.17.20",
    "@types/node": "^24.2.0",
    "@types/react": "~19.1.10",
    "babel-jest": "^29.2.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react-native": "^4.1.0",
    "eslint-plugin-reactotron": "^0.1.2",
    "jest": "^29.2.1",
    "jest-expo": "~54.0.16",
    "patch-package": "^8.0.0",
    "postinstall-prepare": "1.0.1",
    "prettier": "^3.3.3",
    "react-test-renderer": "19.0.0",
    "reactotron-core-client": "^2.9.4",
    "reactotron-mst": "^3.1.7",
    "reactotron-react-js": "^3.3.11",
    "reactotron-react-native": "^5.0.5",
    "reactotron-react-native-mmkv": "^0.2.6",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20.19.4"
  },
  "expo": {
    "install": {
      "exclude": ["react-native-reanimated"]
    }
  },
  "referenceBuildSize": 11
}
